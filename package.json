{
  "name": "raw-ui",
  "version": "0.8.0",
  "description": "Minimalist and customizable React UI library for Web Applications.",
  "main": "dist/cjs/index.js",
  "module": "dist/esm/index.js",
  "types": "dist/index.d.ts",
  "files": [
    "dist",
    "package.json",
    "README.md",
    "LICENSE"
  ],
  "scripts": {
    "build:clear": "rm -rf ./dist",
    "build": "pnpm build:clear && rollup --config rollup.build.config.mjs --environment NODE_ENV:production",
    "dev": "rollup --config ./rollup.config.mjs --watch --environment NODE_ENV:development",
    "docs:dev": "next dev --webpack --port 8000",
    "docs:build": "next build --webpack",
    "changeset": "changeset && changeset version",
    "release": "pnpm build && changeset publish",
    "lint": "pnpm lint:eslint && pnpm lint:tsc",
    "lint:eslint": "eslint .",
    "lint:tsc": "tsc --noEmit",
    "prettier": "prettier --write .",
    "test": "jest",
    "test:update": "jest --updateSnapshot",
    "test:coverage": "jest --coverage",
    "prepare": "husky install"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/shervinchen/raw-ui.git"
  },
  "keywords": [
    "react",
    "design-systems",
    "typescript",
    "react-components",
    "ui-components",
    "ui-library",
    "ui-kit",
    "raw-ui"
  ],
  "author": "shervinchen",
  "license": "MIT",
  "packageManager": "pnpm@10.33.0",
  "bugs": {
    "url": "https://github.com/shervinchen/raw-ui/issues"
  },
  "homepage": "https://github.com/shervinchen/raw-ui#readme",
  "devDependencies": {
    "@babel/core": "^7.24.5",
    "@babel/preset-env": "^7.24.5",
    "@babel/preset-react": "^7.24.1",
    "@babel/preset-typescript": "^7.24.1",
    "@changesets/cli": "^2.26.2",
    "@commitlint/cli": "^20.5.0",
    "@commitlint/config-conventional": "^20.5.0",
    "@eslint/js": "^10.0.1",
    "@mdx-js/loader": "^3.1.1",
    "@mdx-js/react": "^3.1.1",
    "@next/mdx": "^16.2.3",
    "@rollup/plugin-babel": "^7.0.0",
    "@rollup/plugin-commonjs": "^29.0.2",
    "@rollup/plugin-image": "^3.0.3",
    "@rollup/plugin-node-resolve": "^16.0.3",
    "@rollup/plugin-replace": "^6.0.3",
    "@rollup/plugin-terser": "^1.0.0",
    "@rollup/plugin-typescript": "^12.3.0",
    "@tailwindcss/postcss": "^4.2.2",
    "@tailwindcss/typography": "^0.5.9",
    "@testing-library/dom": "^10.4.1",
    "@testing-library/jest-dom": "^6.9.1",
    "@testing-library/react": "^16.3.2",
    "@testing-library/user-event": "^14.6.1",
    "@types/jest": "^30.0.0",
    "@types/lodash": "^4.17.4",
    "@types/mdx": "^2.0.13",
    "@types/node": "^25.6.0",
    "@types/react": "^19.2.14",
    "@types/react-dom": "^19.2.3",
    "babel-jest": "^30.3.0",
    "eslint": "^10.2.0",
    "eslint-config-next": "^16.2.3",
    "eslint-config-prettier": "^10.1.8",
    "eslint-plugin-react": "^7.37.5",
    "husky": "^9.1.7",
    "jest": "^30.3.0",
    "jest-environment-jsdom": "^30.3.0",
    "lint-staged": "^16.4.0",
    "next": "^16.2.3",
    "next-themes": "^0.4.6",
    "postcss": "^8.4.14",
    "prettier": "3.8.2",
    "prism-react-renderer": "^2.4.1",
    "react": "^19.2.5",
    "react-dom": "^19.2.5",
    "react-live": "^4.1.8",
    "rehype-autolink-headings": "^7.1.0",
    "rehype-pretty-code": "^0.14.3",
    "rehype-slug": "^6.0.0",
    "remark-gfm": "^4.0.1",
    "rollup": "^4.17.2",
    "rollup-plugin-dts": "^6.1.0",
    "rollup-plugin-livereload": "^2.0.5",
    "rollup-plugin-peer-deps-external": "^2.2.4",
    "rollup-plugin-postcss": "^4.0.2",
    "rollup-plugin-serve": "^3.0.0",
    "rollup-preserve-directives": "^1.1.3",
    "shiki": "^4.0.2",
    "tailwindcss": "^4.2.2",
    "ts-jest": "^29.1.2",
    "tslib": "^2.4.0",
    "typescript": "^6.0.2",
    "typescript-eslint": "^8.58.1"
  },
  "peerDependencies": {
    "react": "^19.2.5",
    "react-dom": "^19.2.5"
  },
  "dependencies": {
    "classnames": "^2.3.2",
    "lodash": "^4.17.21",
    "react-feather": "^2.0.10",
    "react-remove-scroll": "^2.5.7",
    "react-use": "^17.5.0",
    "styled-jsx": "^5.1.2"
  }
}
